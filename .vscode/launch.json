{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Noor POC Dev Server",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/src/_theme/devserver.py",
      "console": "integratedTerminal",
      "args": ["8474"],
      "serverReadyAction": {
        "pattern": "Noor POC server \\(no-store\\) on (http://localhost:\\d+)",
        "uriFormat": "%s/src/Index.dc.html",
        "action": "openExternally"
      }
    }
  ]
}
